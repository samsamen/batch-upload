{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "steps": {
    "install": {
      "commands": [
        "npm install --prefix backend",
        "npm install --prefix frontend"
      ]
    },
    "build": {
      "commands": [
        "npm run build --prefix frontend",
        "cp -r frontend/dist backend/public"
      ]
    }
  },
  "deploy": {
    "startCommand": "node backend/server.js"
  }
}
